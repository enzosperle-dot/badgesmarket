# =====================================================================
# Copie este arquivo para ".env.local" e preencha com os dados do seu
# projeto Supabase (Project Settings > API).
# =====================================================================

# URL do projeto (ex: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" (pode ficar no frontend — é protegida pelo RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
